NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=shanhai_store
DB_CONNECTION_LIMIT=10
CORS_ORIGIN=http://localhost:5173
# 设置后，除健康检查外的接口需携带 Authorization: Bearer <API_TOKEN>
API_TOKEN=
TOKEN_PEPPER=replace-with-a-long-random-secret
SESSION_TTL_DAYS=30
# 仅非生产环境手机号登录桩使用
DEV_LOGIN_CODE=123456
# 仅非生产环境允许未接第三方 SDK 时联调 OAuth
OAUTH_DEV_MODE=false
PAYMENT_CALLBACK_SECRET=
REFUND_CALLBACK_SECRET=
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3000
